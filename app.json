{
  "expo": {
    "name": "衝動買いストッパー",
    "description": "衝動買いの前に衝動買いチェックして、買うかどうかを落ち着いて判断するためのアプリです。",
    "slug": "shoudo-stopper",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FCFBF8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jikoukan.shoudostopper",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c934214f-712a-45f5-b651-dd59cdfc51dc"
      }
    },
    "owner": "kk0526",
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FCFBF8"
        }
      ]
    ]
  }
}
